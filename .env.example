# ===========================================
# EaseYourEstate — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/easeyourestate

# --- Authentication ---
# JWT secret key — MUST be at least 32 characters long.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=3225e6a23c11ffab1ae96200f5b077034f150e067bf4305a754f72f58c91e97705059c9c998a70ca91f106fc61e5f80c

# --- Admin Setup ---
# Secret key required for first-time admin account creation.
# Set a strong random value. Only needed during initial setup.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SETUP_KEY=c2b92f9763262b132d11bc3e508fed73b1984c7099f3f743

